# Stable instance identity used across compose, docs, and login operations
INSTANCE_SLUG=your-short-name
INSTANCE_NAME=你的公众号显示名

# Bark titles should identify which account needs manual action
BARK_TITLE_PREFIX=[你的公众号显示名]

# Required for noVNC / x11vnc authentication
VNC_PASSWORD=replace-with-a-strong-password
AUTO_OPEN_BROWSER=true

# Optional runtime overrides
# TZ=Asia/Shanghai
# VNC_PORT=5900
# NOVNC_PORT=6080
# SCREEN_WIDTH=1920
# SCREEN_HEIGHT=1080
# SCREEN_DEPTH=24
