# Compose / deployment identity.
# For a second account on the same host, copy this file and change all names and ports.
COMPOSE_PROJECT_NAME=wechat-account-a
CONTAINER_NAME=wechat-publisher-account-a
IMAGE_NAME=wechat-ai-publisher:account-a
HOST_NOVNC_PORT=6080
HOST_VNC_PORT=5900
WECHAT_PROFILE_VOLUME=wechat-profile-account-a

# Required for noVNC / x11vnc authentication
VNC_PASSWORD=你的vnc登录密码
AUTO_OPEN_BROWSER=true

# Optional: uncomment if you want to override defaults from docker-compose.yml
# TZ=Asia/Shanghai
# VNC_PORT=5900
# NOVNC_PORT=6080
# SCREEN_WIDTH=1920
# SCREEN_HEIGHT=1080
# SCREEN_DEPTH=24
